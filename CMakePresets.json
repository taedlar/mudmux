{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "hidden": true,
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_POSITION_INDEPENDENT_CODE": "ON",
                "CMAKE_CXX_STANDARD": "17",
                "CMAKE_CXX_STANDARD_REQUIRED": "ON",
                "CMAKE_PROJECT_TOP_LEVEL_INCLUDES": "${sourceDir}/cmake/setup.cmake"
            }
        },
        {
            "name": "linux-default",
            "hidden": true,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-gcc",
            "inherits": ["default", "linux-default"],
            "description": "Configure the project for Linux using GCC.",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        },
        {
            "name": "linux-clang",
            "inherits": ["default", "linux-default"],
            "description": "Configure the project for Linux using Clang.",
            "generator": "Ninja Multi-Config",
            "cacheVariables": {
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "msvc-default",
            "hidden": true,
            "cacheVariables": {
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded$<$<CONFIG:Debug>:Debug>DLL"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "vs16-x64",
            "inherits": ["default", "msvc-default"],
            "description": "Configure the project for Visual Studio 2019 x64.",
            "generator": "Visual Studio 16 2019",
            "architecture": {
              "value": "x64",
              "strategy": "set"
            }
        },
        {
            "name": "vs18-x64",
            "inherits": ["default", "msvc-default"],
            "description": "Configure the project for Visual Studio 2026 x64.",
            "generator": "Visual Studio 18 2026",
            "architecture": {
              "value": "x64",
              "strategy": "set"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev-linux-gcc",
            "configurePreset": "linux-gcc",
            "description": "Development build",
            "targets": ["all"],
            "configuration": "Debug"
        },
        {
            "name": "rel-linux-gcc",
            "inherits": ["dev-linux-gcc"],
            "description": "Release build with debug information",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "dev-linux-clang",
            "configurePreset": "linux-clang",
            "description": "Development build",
            "targets": ["all"],
            "configuration": "Debug"
        },
        {
            "name": "rel-linux-clang",
            "inherits": ["dev-linux-clang"],
            "description": "Release build with debug information",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "dev-vs16-x64",
            "configurePreset": "vs16-x64",
            "description": "Development build",
            "targets": ["ALL_BUILD"],
            "configuration": "Debug"
        },
        {
            "name": "rel-vs16-x64",
            "inherits": ["dev-vs16-x64"],
            "description": "Release build with debug information",
            "configuration": "RelWithDebInfo"
        },
        {
            "name": "dev-vs18-x64",
            "configurePreset": "vs18-x64",
            "description": "Development build",
            "targets": ["ALL_BUILD"],
            "configuration": "Debug"
        },
        {
            "name": "rel-vs18-x64",
            "inherits": ["dev-vs18-x64"],
            "description": "Release build with debug information",
            "configuration": "RelWithDebInfo"
        }
    ],
    "testPresets": [
        {
            "name": "units-linux-gcc",
            "configurePreset": "linux-gcc",
            "description": "Run tests on Linux using GCC."
        },
        {
            "name": "units-linux-clang",
            "configurePreset": "linux-clang",
            "description": "Run tests on Linux using Clang."
        },
        {
            "name": "units-vs16-x64",
            "configurePreset": "vs16-x64",
            "description": "Run tests on Windows using Visual Studio 2019 x64."
        },
        {
            "name": "units-vs18-x64",
            "configurePreset": "vs18-x64",
            "description": "Run tests on Windows using Visual Studio 2026 x64."
        }
    ]
}
